exports[`ParsePanel composition (spec §5) > renders one StagedReviewCard per row, in input order, mounting the actionable-warnings leaf > staged-card-chrome-around-first-card 1`] = `"<article data-testid="staged-review-card" data-staged-id="staged-a-0000-4000-8000-000000000000" data-drive-file-id="drive-a" class="rounded-md border border-border-strong bg-surface-raised p-tile-pad shadow-tile"><header class="mb-4 space-y-1"><p class="text-xs font-medium uppercase tracking-eyebrow text-text-subtle" data-testid="staged-source-kind">Auto sync</p><div class="flex flex-wrap items-center gap-2"><h3 class="text-base font-semibold text-text-strong" data-testid="staged-parse-summary">East Coast Load-In</h3></div><p class="text-sm text-text-subtle">Staged </p><ul class="flex flex-col gap-2" data-testid="per-show-actionable-warnings"></ul></header><p class="text-sm text-text-subtle" data-testid="staged-review-no-items">Nothing to decide here. You can apply this change as-is.</p><div class="mt-6 flex flex-wrap gap-2"><button type="button" class="min-h-tap-min rounded-sm bg-accent text-accent-text transition-colors duration-fast hover:bg-accent-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-focus-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-60 min-w-tap-min px-4 py-2 font-medium focus-visible:ring-offset-surface-raised" data-testid="staged-review-apply" aria-busy="false">Apply this change</button><button type="button" data-testid="staged-review-discard-try-again" aria-busy="false" class="min-h-tap-min rounded-sm border border-border-strong bg-surface px-4 py-2 font-medium text-text-strong transition-colors duration-fast hover:bg-surface-sunken focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-focus-ring focus-visible:ring-offset-2 focus-visible:ring-offset-surface-raised disabled:cursor-not-allowed disabled:opacity-60">Retry on next sync</button></div></article>"`;

export const POST = withAdmin(withRateLimit(async (req: Request) => {
  return supabase.from(tableName).select("*");
}));

export const PUT = withRateLimit(withAdmin(async (req: Request) => {
  return supabase.from(tableName).select("*");
}));

export const PATCH = withRateLimit(60, async (req: Request) => {
  return supabase.from(tableName).select("*");
});

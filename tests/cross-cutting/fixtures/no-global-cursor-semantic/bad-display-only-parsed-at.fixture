export async function discardStagedParse(db: QueryClient, reviewedParsedAt: string, stagedId: string) {
  const staged = await db.from("pending_syncs").select("parsed_at").eq("staged_id", stagedId).single();
  if (staged.data.parsed_at === reviewedParsedAt) {
    await db.from("pending_syncs").delete().eq("staged_id", stagedId);
  }
}

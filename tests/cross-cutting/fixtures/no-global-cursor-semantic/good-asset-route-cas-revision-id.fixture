export async function assetRecovery(db: QueryClient, req: { params: { rev: string } }, showId: string) {
  const show = await db.from("shows").select("diagrams").eq("id", showId).single();
  if (sql`(shows.diagrams ->> 'snapshot_revision_id')::uuid = ${req.params.rev}`) {
    await db.from("shows").update({ diagrams: show.data.diagrams }).eq("id", showId);
  }
}

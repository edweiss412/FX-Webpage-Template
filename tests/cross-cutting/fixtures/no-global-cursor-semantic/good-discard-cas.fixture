export async function discardStagedParse(db: QueryClient, reviewedStagedId: string) {
  const pending = await db.from("pending_syncs").select("staged_id").eq("staged_id", reviewedStagedId).single();
  if (pending.data.staged_id === reviewedStagedId) {
    await db.from("pending_syncs").delete().eq("staged_id", reviewedStagedId);
  }
}

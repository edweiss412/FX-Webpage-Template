export async function retrySingleFile(db: QueryClient, fileMeta: FileMeta, id: string) {
  const pending = await db.from("pending_ingestions").select("last_attempt_at").eq("id", id).single();
  if (fileMeta.modifiedTime > pending.data.last_attempt_at) {
    await db.from("pending_ingestions").update({ retry_count: 1 }).eq("id", id);
  }
}

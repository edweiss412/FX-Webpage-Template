{
  "name": "fx-webpage-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/with-admin-dev-flag.mjs next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:internal-code-enums": "tsx scripts/extract-internal-code-enums.ts",
    "gen:spec-codes": "tsx scripts/extract-spec-codes.ts",
    "typecheck": "tsc --noEmit",
    "verify:spec-amendment": "scripts/verify-spec-amendment-3.sh",
    "test:audit:x1-catalog-parity": "pnpm gen:spec-codes && vitest run tests/cross-cutting/",
    "test:audit:x2-no-raw-codes": "pnpm gen:internal-code-enums && vitest run tests/cross-cutting/no-raw-codes.test.ts",
    "db:seed": "pnpm dlx tsx supabase/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:parser": "vitest run tests/parser tests/invariants",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.6",
    "@octokit/rest": "^22.0.1",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "pdfjs-dist": "^5.7.284",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-pdf": "^10.4.1",
    "react-zoom-pan-pinch": "^4.0.3",
    "xlsx": "^0.18.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}

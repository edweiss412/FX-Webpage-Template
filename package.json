{
  "name": "fx-webpage-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/with-admin-dev-flag.mjs next build",
    "start": "next start",
    "prepare": "simple-git-hooks",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validation:reseed": "tsx scripts/validation-reseed.ts",
    "validation:smoke": "tsx scripts/validation-smoke.ts",
    "validation:check-seed": "tsx scripts/validation-check-seed.ts",
    "validation:resolve-alias": "tsx scripts/validation-resolve-alias.ts",
    "validation:report-fixtures": "tsx scripts/validation-report-fixtures.ts",
    "gen:internal-code-enums": "tsx scripts/extract-internal-code-enums.ts",
    "gen:admin-tables": "tsx scripts/generate-admin-tables.ts",
    "gen:watermark-symbols": "tsx scripts/extract-watermark-symbols.ts",
    "gen:email-boundaries": "tsx scripts/extract-email-boundaries.ts",
    "gen:traceability": "tsx scripts/generate-traceability.ts",
    "gen:spec-codes": "tsx scripts/extract-spec-codes.ts",
    "gen:schema-manifest": "tsx scripts/generate-schema-manifest.ts",
    "observe": "tsx scripts/observe.ts",
    "spec:lint": "tsx scripts/spec-lint.ts",
    "pretypecheck": "node scripts/pretest-gen.mjs",
    "typecheck": "tsc --noEmit",
    "prelint": "node scripts/pretest-gen.mjs",
    "pretest": "node scripts/pretest-gen.mjs",
    "prebuild": "node scripts/pretest-gen.mjs",
    "verify:spec-amendment": "scripts/verify-spec-amendment-3.sh",
    "test:audit:x1-catalog-parity": "pnpm gen:spec-codes && vitest run tests/cross-cutting/codes.test.ts tests/cross-cutting/extract-spec-codes.test.ts",
    "test:audit:x2-no-raw-codes": "pnpm gen:internal-code-enums && vitest run tests/cross-cutting/no-raw-codes.test.ts",
    "test:audit:x3-trust-domain": "pnpm gen:admin-tables && vitest run tests/cross-cutting/no-jwt-surface.test.ts tests/cross-cutting/no-m9-5-surfaces.test.ts tests/cross-cutting/picker-resolver-callsite-contract.test.ts tests/cross-cutting/resolve-show-page-access-exhaustiveness.test.ts tests/cross-cutting/auth-chain-audit.test.ts",
    "test:audit:x4-no-global-cursor": "pnpm gen:watermark-symbols && vitest run tests/cross-cutting/no-global-cursor.test.ts",
    "test:audit:x5-email-canonicalization": "pnpm gen:email-boundaries && vitest run tests/cross-cutting/email-canonicalization.test.ts",
    "test:audit:x6-pg-cron-pivot": "vitest run tests/cross-cutting/no-vercel-cron.test.ts tests/cross-cutting/pg-cron-pivot-doc-guard.test.ts tests/cross-cutting/m12-plan-pg-cron-pivot-amendment.test.ts tests/cross-cutting/no-vestigial-middleware.test.ts",
    "test:audit:traceability": "pnpm gen:traceability && vitest run tests/cross-cutting/traceability.test.ts",
    "test:audit:branch-protection": "vitest run tests/cross-cutting/verify-branch-protection.test.ts",
    "test:audit:validation-schema-parity": "vitest run tests/db/schema-manifest-lib.test.ts tests/db/validation-schema-parity.test.ts",
    "db:seed": "pnpm dlx tsx supabase/seed.ts",
    "screenshot:help": "ENABLE_TEST_AUTH=true TEST_AUTH_SECRET=test-secret-fixture playwright test -c playwright.screenshots.config.ts --project=screenshots-help --project=screenshots-help-capture",
    "test": "vitest run",
    "test:fast": "pnpm pretest && node scripts/test-fast.mjs",
    "test:watch": "vitest",
    "test:parser": "vitest run tests/parser tests/invariants",
    "test:fuzz": "vitest run tests/parser/fuzz",
    "test:fuzz:deep": "FUZZ_DEEP=1 vitest run tests/parser/fuzz",
    "test:e2e": "playwright test",
    "test:e2e:modal-header": "playwright test --config=tests/e2e/standalone.config.ts tests/e2e/skeletonBandParity.spec.ts tests/e2e/statusStripToggleLayout.spec.ts tests/e2e/step3-review-modal.layout.spec.ts",
    "test:e2e:attention-anchor": "playwright test --config=tests/e2e/standalone.config.ts tests/e2e/attention-anchor-placement.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "verify-resync-scheduletimes": "tsx scripts/verify-resync-scheduletimes.ts",
    "worktree:link-env": "bash scripts/worktree-link-env.sh",
    "preflight": "node scripts/preflight-env.mjs",
    "db:reset-pool": "node scripts/db-reset-pool.mjs",
    "test:e2e:hoverhelp-geometry": "playwright test --config=tests/e2e/standalone.config.ts tests/e2e/hoverhelp-geometry.spec.ts"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/env": "16.2.4",
    "@next/mdx": "^16.2.6",
    "@octokit/rest": "^22.0.1",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "embla-carousel-react": "^8.6.0",
    "fflate": "^0.8.3",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.10",
    "pdfjs-dist": "5.4.296",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-pdf": "^10.4.1",
    "react-zoom-pan-pinch": "^4.0.3",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.4",
    "tz-lookup": "6.1.25",
    "xlsx": "^0.18.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/tz-lookup": "6.1.2",
    "@types/ws": "^8.18.1",
    "@vitest/ui": "^4.1.5",
    "esbuild": "0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "fast-check": "^4.9.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.4",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "ws": "^8.21.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,jsonc,css,scss,yml,yaml,md,mdx,html}": "prettier --write --ignore-unknown"
  }
}

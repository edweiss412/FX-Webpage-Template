# Supabase
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
DATABASE_URL=
# Google
GOOGLE_SERVICE_ACCOUNT_JSON=
M6_REAL_DRIVE_FIXTURE_SPREADSHEET_ID=
M6_REAL_DRIVE_FIXTURE_FOLDER_ID=
# Auth
JWT_SIGNING_SECRET=
# Realtime — required by /api/realtime/subscriber-token (M4 Task 4.16). The
# JWT secret signs the short-lived (5-min) HS256 tokens the client island
# passes to supabase.realtime.setAuth(jwt). Issuer goes into the iss claim.
SUPABASE_JWT_SECRET=
SUPABASE_REALTIME_ISS=
# GitHub
GITHUB_API_TOKEN=
GITHUB_REPO=edweiss412/FX-Webpage-Template
# the GitHub username the PAT belongs to; required for /api/report recovery (Task 8.3d)
GITHUB_BOT_LOGIN=
# Sentry
SENTRY_DSN=
# Admin allowlist
# RETIRED 2026-05-14 (M9 C9 / M2-D1). Was never consumed by any code
# path; the live public.is_admin() array was migration-hardcoded. Admin
# allow-list is now table-driven via public.admin_emails (seed inserts
# dlarson@fxav.net + edweiss412@gmail.com). Operator adds/revokes via
# /admin/settings/admins. See:
#   docs/superpowers/specs/amendments/2026-05-14-admin-allowlist-runtime-mutable.md
# Webhook
DRIVE_WEBHOOK_BASE_URL=
# NB: WATCHED_DRIVE_FOLDER_ID is NOT an env var — see §14.3 / §4.5.

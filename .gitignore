# Hook audit log for codex-companion adversarial-review prompts (~/.claude/hooks/check-codex-adversarial-review-fresh-eyes.sh)
.codex-adversarial-review-audit.log

# pnpm content-addressable store (created when Docker pinned-image runs pnpm install with $PWD mounted at /work)
.pnpm-store/

# Playwright test-results scratch dir (created by screenshot capture + walker runs)
tmp/

# M12 rate-limit fixture snapshot files (created by `pnpm validation:report-fixtures
# --outcome rate-limit-admin|rate-limit-crew` per the F34/F36 snapshot+restore contracts;
# `validation_state` cannot be used as backend due to `CHECK (key = 'validation_seed')`
# singleton constraint — file-backed is the sole supported strategy per R41 F37)
.validation-state/

# M12 Phase 1 walk launchpad (local-only; embeds live validation share-tokens — must never be committed)
.validation-local/

.build-locks/

# Codex companion per-run state (broker sockets, session/thread IDs, prompts) — never source
.codex-companion*/

# Subagent-driven-development working files (briefs/reports/diffs). Canonical
# location is the git-dir (`git rev-parse --git-path sdd`); a working-tree `sdd/`
# is a stray relative-path write and must never be committed.
sdd/

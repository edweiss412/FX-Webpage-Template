{
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/keepalive",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/refresh-watch",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/gc-watch",
      "schedule": "15 * * * *"
    }
  ]
}
